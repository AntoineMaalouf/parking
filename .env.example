# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Pushover (https://pushover.net/api) ──────────────────────────────────────
# Application API token — create one at https://pushover.net/apps/build
PUSHOVER_API_TOKEN=

# Your personal user key — shown on your Pushover dashboard
PUSHOVER_USER_KEY=
